---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const benefits = [
  t(lang, 'videocall.benefit1'),
  t(lang, 'videocall.benefit2'),
  t(lang, 'videocall.benefit3'),
];
---

<section id="videocall" class="relative py-16 sm:py-24 bg-surface-950 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 dot-grid opacity-30"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-primary-500/5 rounded-full blur-[120px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="relative rounded-2xl glass border border-white/10 p-8 sm:p-12 text-center glow-sm reveal">
        <!-- Duration badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-500/10 text-primary-400 rounded-full text-sm font-medium mb-6 border border-primary-500/20">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          {t(lang, 'videocall.duration')}
        </div>

        <!-- Headline -->
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="font-family: var(--font-display);">
          {t(lang, 'videocall.headline')}
        </h2>
        <p class="text-lg text-surface-400 mb-8 leading-relaxed">
          {t(lang, 'videocall.subheadline')}
        </p>

        <!-- Benefits -->
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 justify-center mb-8 stagger-children">
          {benefits.map((benefit) => (
            <div class="flex items-center gap-2 text-left">
              <svg class="w-5 h-5 shrink-0 text-cyber-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-surface-300">{benefit}</span>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <a
          href="#"
          class="btn-glow btn-press inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-full"
          data-videocall-cta
        >
          <svg class="mr-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          {t(lang, 'videocall.cta')}
        </a>

        <!-- No commitment -->
        <p class="mt-4 text-sm text-surface-500">
          {t(lang, 'videocall.nocommit')}
        </p>
      </div>
    </div>
  </div>
</section>
