---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const losers = [
  {
    key: 'agency',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    color: 'red',
  },
  {
    key: 'freelancer',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
    color: 'red',
  },
  {
    key: 'diy',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    color: 'amber',
  },
];

const tableFeatures = ['leads', 'creatives', 'followup', 'booking', 'optimization', 'cost', 'commitment'] as const;
const tableColumns = ['agency', 'freelancer', 'diy', 'leadflow'] as const;
---

<section class="relative py-16 sm:py-24 bg-surface-950 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 dot-grid opacity-30"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- PART 1: The emotional story -->
    <div class="max-w-3xl mx-auto text-center mb-16 sm:mb-20">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white reveal" style="font-family: var(--font-display);">
        {t(lang, 'compare.headline')}
      </h2>

      <div class="mt-8 space-y-4 text-base sm:text-lg text-surface-400 reveal">
        <p>{t(lang, 'compare.story.p1')}</p>
        <p>{t(lang, 'compare.story.p2')}</p>
        <p class="text-surface-300">{t(lang, 'compare.story.p3')}</p>
      </div>

      <!-- The highlight question -->
      <div class="mt-8 reveal">
        <p class="text-xl sm:text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-cyber-400">
          {t(lang, 'compare.story.highlight')}
        </p>
      </div>
    </div>

    <!-- PART 2: Comparison cards -->
    <div class="mb-16 sm:mb-20">
      <h3 class="text-xl sm:text-2xl font-bold text-white text-center mb-8 reveal" style="font-family: var(--font-display);">
        {t(lang, 'compare.options.headline')}
      </h3>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 stagger-children">
        <!-- Agency, Freelancer, DIY cards (negative) -->
        {losers.map((item) => (
          <div class="relative p-6 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-red-500/20 hover:border-red-500/40 transition-all duration-300">
            <div class="flex items-center gap-3 mb-4">
              <div class={`w-10 h-10 rounded-xl bg-red-500/10 text-red-400 flex items-center justify-center border border-red-500/20`}>
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <h4 class="text-white font-bold text-sm">{t(lang, `compare.${item.key}.title`)}</h4>
                <p class="text-red-400 text-xs font-semibold">{t(lang, `compare.${item.key}.price`)}</p>
              </div>
            </div>
            <p class="text-surface-500 text-sm mb-4">{t(lang, `compare.${item.key}.desc`)}</p>
            <div class="space-y-2.5">
              {[1, 2, 3].map((n) => (
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  <span class="text-surface-500 text-xs leading-relaxed">{t(lang, `compare.${item.key}.con${n}`)}</span>
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- LeadFlow card (positive, highlighted) -->
        <div class="relative p-6 rounded-2xl bg-white/[0.05] backdrop-blur-sm border border-accent-400/30 hover:border-accent-400/50 transition-all duration-300 glow-accent">
          <!-- Best option badge -->
          <div class="absolute -top-3 right-4">
            <span class="px-3 py-1 bg-accent-500 text-white text-xs font-bold rounded-full shadow-lg shadow-accent-500/20">
              ✓
            </span>
          </div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-accent-500/10 text-accent-400 flex items-center justify-center border border-accent-500/20">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-white font-bold text-sm">{t(lang, 'compare.leadflow.title')}</h4>
              <p class="text-accent-400 text-xs font-semibold">{t(lang, 'compare.leadflow.price')}</p>
            </div>
          </div>
          <p class="text-surface-400 text-sm mb-4">{t(lang, 'compare.leadflow.desc')}</p>
          <div class="space-y-2.5">
            {[1, 2, 3].map((n) => (
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-accent-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-surface-300 text-xs leading-relaxed">{t(lang, `compare.leadflow.pro${n}`)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- PART 3: Feature comparison table -->
    <div class="mb-16 sm:mb-20 reveal">
      <h3 class="text-xl sm:text-2xl font-bold text-white text-center mb-8" style="font-family: var(--font-display);">
        {t(lang, 'compare.table.headline')}
      </h3>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left text-sm font-semibold text-surface-400 p-4 border-b border-white/10">
                {t(lang, 'compare.table.feature')}
              </th>
              {tableColumns.map((col) => (
                <th class={`text-center text-sm font-semibold p-4 border-b ${col === 'leadflow' ? 'text-accent-400 border-accent-400/30 bg-accent-500/5' : 'text-surface-400 border-white/10'}`}>
                  {t(lang, `compare.${col}.title`)}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {tableFeatures.map((feature, i) => (
              <tr class={i % 2 === 0 ? 'bg-white/[0.02]' : ''}>
                <td class="text-sm font-medium text-surface-300 p-4 border-b border-white/5">
                  {t(lang, `compare.table.${feature}`)}
                </td>
                {tableColumns.map((col) => (
                  <td class={`text-center text-sm p-4 border-b border-white/5 ${col === 'leadflow' ? 'text-accent-400 font-semibold bg-accent-500/5' : col === 'diy' ? 'text-amber-400/70' : 'text-red-400/70'}`}>
                    {t(lang, `compare.table.${col}.${feature}`)}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile: scrollable cards -->
      <div class="md:hidden space-y-3">
        {tableFeatures.map((feature) => (
          <div class="rounded-xl bg-white/[0.03] border border-white/10 p-4">
            <p class="text-xs font-semibold text-surface-400 uppercase tracking-wider mb-3">
              {t(lang, `compare.table.${feature}`)}
            </p>
            <div class="grid grid-cols-2 gap-2">
              {tableColumns.map((col) => (
                <div class={`rounded-lg p-2 text-center ${col === 'leadflow' ? 'bg-accent-500/10 border border-accent-500/20' : 'bg-white/[0.03]'}`}>
                  <p class={`text-[10px] font-medium mb-0.5 ${col === 'leadflow' ? 'text-accent-400' : 'text-surface-500'}`}>
                    {t(lang, `compare.${col}.title`)}
                  </p>
                  <p class={`text-xs font-semibold ${col === 'leadflow' ? 'text-accent-300' : col === 'diy' ? 'text-amber-400/80' : 'text-red-400/80'}`}>
                    {t(lang, `compare.table.${col}.${feature}`)}
                  </p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- PART 4: Psychological trigger + CTA -->
    <div class="max-w-2xl mx-auto text-center reveal">
      <div class="relative p-8 sm:p-10 rounded-2xl bg-gradient-to-br from-red-500/10 via-transparent to-accent-500/10 border border-white/10">
        <p class="text-base sm:text-lg text-surface-300 italic leading-relaxed">
          {t(lang, 'compare.trigger')}
        </p>
        <div class="mt-6">
          <a
            href="#hero"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-primary-500 to-cyber-400 text-white font-bold rounded-full shadow-lg shadow-primary-500/25 hover:shadow-primary-500/40 hover:scale-105 transition-all duration-300"
          >
            {t(lang, 'compare.cta')}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
