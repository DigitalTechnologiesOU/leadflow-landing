---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const faqs = Array.from({ length: 12 }, (_, i) => ({
  question: t(lang, `faq.${i + 1}.q`),
  answer: t(lang, `faq.${i + 1}.a`),
}));
---

<section id="faq" class="py-16 sm:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold text-surface-900" style="font-family: var(--font-display);">
        {t(lang, 'faq.headline')}
      </h2>
    </div>

    <div class="space-y-4 stagger-children">
      {faqs.map((faq, index) => (
        <details class="group rounded-2xl border border-surface-200 bg-white/80 backdrop-blur-sm hover:border-primary-300/40 transition-colors" open={index === 0}>
          <summary class="flex items-center justify-between cursor-pointer p-6 text-left">
            <h3 class="text-base font-semibold text-surface-900 pr-4">
              {faq.question}
            </h3>
            <svg class="w-5 h-5 text-primary-400 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-surface-500 leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
