---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-12 sm:py-16 bg-surface-50 border-y border-surface-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <!-- Founder placeholder -->
    <div class="flex items-center justify-center gap-3 mb-6">
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-cyber-400 flex items-center justify-center shadow-md shadow-primary-500/20">
        <span class="text-white font-bold text-sm">LF</span>
      </div>
      <div class="text-left">
        <p class="text-sm font-semibold text-surface-900">{t(lang, 'social.founder.name')}</p>
        <p class="text-xs text-surface-500">{t(lang, 'social.founder.title')}</p>
      </div>
    </div>

    <p class="text-2xl sm:text-3xl font-bold text-surface-900" style="font-family: var(--font-display);">
      {t(lang, 'social.headline')}
    </p>
    <p class="mt-3 text-base text-surface-500 max-w-2xl mx-auto">
      {t(lang, 'social.subheadline')}
    </p>

    <!-- Trust Badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-6 sm:gap-10 stagger-children">
      <div class="flex items-center gap-2 text-surface-600">
        <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-sm font-medium">{t(lang, 'social.badge.meta')}</span>
      </div>
      <div class="flex items-center gap-2 text-surface-600">
        <svg class="w-6 h-6 text-cyber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <span class="text-sm font-medium">{t(lang, 'social.badge.gdpr')}</span>
      </div>
      <div class="flex items-center gap-2 text-surface-600">
        <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <span class="text-sm font-medium">{t(lang, 'social.badge.ai')}</span>
      </div>
      <div class="flex items-center gap-2 text-surface-600">
        <svg class="w-6 h-6 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
        </svg>
        <span class="text-sm font-medium">{t(lang, 'social.badge.nodata')}</span>
      </div>
    </div>
  </div>
</section>
