---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const problems = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: t(lang, 'problem.1.title'),
    description: t(lang, 'problem.1.description'),
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: t(lang, 'problem.2.title'),
    description: t(lang, 'problem.2.description'),
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: t(lang, 'problem.3.title'),
    description: t(lang, 'problem.3.description'),
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>`,
    title: t(lang, 'problem.4.title'),
    description: t(lang, 'problem.4.description'),
  },
];
---

<section class="relative py-16 sm:py-24 dot-grid-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Image + headline -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-12 sm:mb-16">
      <div class="relative rounded-2xl overflow-hidden aspect-[4/3] reveal-left border border-surface-200">
        <img
          src={`${base}/images/gym-training.jpg`}
          alt={t(lang, 'problem.img.alt')}
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-surface-900/40 to-transparent"></div>
      </div>
      <div class="text-center lg:text-left reveal-right">
        <h2 class="text-3xl sm:text-4xl font-bold text-surface-900" style="font-family: var(--font-display);">
          {t(lang, 'problem.headline')}
        </h2>
        <p class="mt-4 text-lg text-surface-500">
          {t(lang, 'problem.intro')}
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {problems.map((problem) => (
        <div class="group relative p-6 rounded-2xl bg-white/80 backdrop-blur-sm border border-surface-200 hover:border-red-300/50 card-hover">
          <div class="w-12 h-12 rounded-xl bg-red-50 text-red-500 flex items-center justify-center mb-4 group-hover:bg-red-100 transition-colors border border-red-100">
            <Fragment set:html={problem.icon} />
          </div>
          <h3 class="text-base font-bold text-surface-900 mb-2">
            {problem.title}
          </h3>
          <p class="text-sm text-surface-500 leading-relaxed">
            {problem.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
